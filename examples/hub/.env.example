# ws2m hub — environment variables
# Copy to .env and fill in the required values.

# Required
WS2M_MQTT_HOST=192.168.1.10

# Optional — uncomment and edit as needed
# WS2M_MQTT_PORT=1883
# WS2M_MQTT_USERNAME=
# WS2M_MQTT_PASSWORD=
# WS2M_MQTT_CLIENT_ID=ws2m
# WS2M_SELF_TOPIC_ROOT=ws2m
# WS2M_HASS_TOPIC_ROOT=homeassistant
# WS2M_HASS_DISCOVERY=true
# WS2M_USB_DONGLE=auto              # "auto" or "/dev/hidraw0" (specific path)
# WS2M_HUB_WS_ENABLED=false         # set to true to accept remote ws2m-remote connections
# WS2M_HUB_WS_PORT=8765              # WebSocket port for remote connections
# WS2M_HUB_REMOTE_PAIRING_SECONDS=60        # how long remote pairing mode stays active
# WS2M_LOG_LEVEL=INFO

# Volume / device paths
VOL_DATA=./data
# DEV_WYZESENSE=/dev/hidraw0         # uncomment if hub has a local USB dongle

TZ=UTC
