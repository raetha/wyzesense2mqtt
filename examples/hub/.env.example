# ws2m hub — environment variables
# Copy to .env and fill in the required values.

# ── Required — core config ────────────────────────────────────────────────────
VOL_DATA=./data

# ── Optional — core config ────────────────────────────────────────────────────
# IMAGE_TAG=latest
# TZ=UTC
# WS2M_DATA_DIR=/app/data                 # override data directory (default matches VOL_DATA below)
# DEV_DONGLE=/dev/hidraw0                 # uncomment if hub has a local USB dongle
# VOL_DEV_WS2M_DONGLES=/dev/ws2m-dongles  # uncomment if using the example UDEV rule

# ── Required — mqtt config ────────────────────────────────────────────────────
# WS2M_MQTT_HOST is the only truly required setting — all others have
# sensible defaults. MQTT_USERNAME and MQTT_PASSWORD are only needed if
# your broker requires authentication.
#
WS2M_MQTT_HOST=192.168.1.10
# WS2M_MQTT_PORT=1883
# WS2M_MQTT_USERNAME=
# WS2M_MQTT_PASSWORD=

# ── Optional — mqtt config ────────────────────────────────────────────────────
# WS2M_MQTT_CLIENT_ID=ws2m
# WS2M_SELF_TOPIC_ROOT=ws2m
# WS2M_HASS_TOPIC_ROOT=homeassistant
# WS2M_HASS_DISCOVERY=true

# ── Optional — adjustable from Home Assistant ─────────────────────────────────
# These settings can be changed live from the hub device page in HA and
# are saved to config.yaml automatically. If set here, the env value takes
# precedence over any value saved by HA — changes made in HA will appear
# to have no effect until the env var is removed or updated. Only set
# these here if you need to pin them and do not want HA to control them.
#
# WS2M_DONGLE=auto                        # "auto" or "/dev/hidraw0" (specific path)
# WS2M_LOG_LEVEL=INFO
# WS2M_HUB_WS_ENABLED=false               # set to true to accept remote ws2m-remote connections
# WS2M_HUB_WS_PORT=8765                   # WebSocket port for remote connections
# WS2M_HUB_REMOTE_PAIRING_SECONDS=60  # how long remote pairing mode stays active
