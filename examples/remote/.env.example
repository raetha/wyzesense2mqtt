# ws2m remote — environment variables
# Copy to .env and fill in the values relevant to your setup.

# Hub URL — optional when mDNS discovery is available on your network.
# Set this if the remote cannot discover the hub automatically (e.g. across VLANs,
# in Docker without host networking, or when mDNS is blocked).
# WS2M_HUB_URL=ws://192.168.1.10:8765

# Optional — uncomment and edit as needed
# WS2M_HUB_TOKEN=...                # Set automatically after adoption; do not set manually
# WS2M_REMOTE_ID=...                # Override stable remote UUID (default: loaded from data dir)
# WS2M_DATA_DIR=/app/data           # Data directory for remote_id / hub_token
# WS2M_DEVICE=auto                  # HID device path or "auto" (auto-detects VID 1a86 / PID e024)
# LOG_LEVEL=INFO
# WS2M_DISCOVERY_TIMEOUT=30         # mDNS discovery timeout in seconds (default: 30)
# WS2M_HUB_ID=                      # Preferred hub_id for mDNS multi-hub selection (optional)

DEV_WYZESENSE=/dev/hidraw0
TZ=UTC
