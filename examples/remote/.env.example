# ws2m remote — environment variables
# Copy to .env and fill in the values relevant to your setup.

# ── Required - core config ────────────────────────────────────────────────────
DEV_DONGLE=/dev/hidraw0
VOL_DATA=./data

# ── Optional — core config ────────────────────────────────────────────────────
# IMAGE_TAG=latest
# TZ=UTC
# WS2M_DATA_DIR=/app/data      # override data directory (default matches VOL_DATA below)

# ── Optional — hub connection ─────────────────────────────────────────────────
# Leave WS2M_HUB_URL unset to discover the hub automatically via mDNS.
# Set this if the remote cannot find the hub automatically (e.g. across VLANs,
# in Docker without host networking, or when mDNS is blocked).
# WS2M_HUB_URL=ws://192.168.1.10:8765
# WS2M_HUB_ID=                 # preferred hub_id for mDNS multi-hub selection
# WS2M_DISCOVERY_TIMEOUT=30    # mDNS discovery timeout in seconds

# ── Optional — adjustable from Home Assistant ─────────────────────────────────
# These settings can be changed live from the remote device page in HA and
# are saved to config.yaml automatically. If set here, the env value takes
# precedence over any value saved by HA — changes made in HA will appear
# to have no effect until the env var is removed or updated. Only set
# these here if you need to pin them and do not want HA to control them.
# WS2M_DONGLE=auto             # "auto" or "/dev/hidraw0" (specific path)
# WS2M_LOG_LEVEL=INFO
